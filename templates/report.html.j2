<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Gaming Laptop Checker Report</title>
  <style>
    :root {
      --bg: #0b0f14;
      --panel: #111827;
      --panel-2: #172033;
      --text: #e5e7eb;
      --muted: #9ca3af;
      --line: #263244;
      --green: #16a34a;
      --amber: #d97706;
      --red: #dc2626;
      --gray: #6b7280;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: Consolas, "Segoe UI", system-ui, sans-serif;
      line-height: 1.5;
    }
    .wrap { max-width: 1180px; margin: 0 auto; padding: 28px 18px 48px; }
    header { border-bottom: 1px solid var(--line); padding-bottom: 18px; margin-bottom: 22px; }
    h1 { margin: 0; font-size: 32px; color: #00ff41; }
    h2 { margin: 0 0 12px; font-size: 20px; }
    .muted { color: var(--muted); }
    .verdict {
      display: inline-flex;
      align-items: center;
      margin-top: 16px;
      padding: 10px 14px;
      border: 1px solid var(--line);
      font-weight: 800;
      letter-spacing: 0;
      background: var(--panel);
    }
    .PASS { color: var(--green); }
    .WARN, .NEEDS { color: var(--amber); }
    .FAIL { color: var(--red); }
    .SKIP { color: var(--gray); }
    .grid { display: grid; gap: 14px; }
    .summary { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-bottom: 24px; }
    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 14px;
    }
    .metric { color: #00ff41; font-weight: 700; word-break: break-word; }
    .results { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
    .badge { float: right; font-weight: 800; }
    pre {
      white-space: pre-wrap;
      max-height: 180px;
      overflow: auto;
      background: #070a0f;
      padding: 10px;
      border: 1px solid var(--line);
    }
    canvas { width: 100%; height: 280px; background: #070a0f; border: 1px solid var(--line); }
    ul { margin: 0; padding-left: 18px; }
    li { margin-bottom: 6px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; border-bottom: 1px solid var(--line); padding: 8px; vertical-align: top; }
    th { color: #00ff41; }
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <h1>Gaming Laptop Checker</h1>
      <div class="muted">{{ payload.suite_name }} | {{ payload.started_at }} - {{ payload.finished_at }}</div>
      <div class="verdict {{ payload.overall_status.split()[0] }}">Overall Verdict: {{ payload.overall_status }}</div>
    </header>

    <section>
      <h2>System Summary</h2>
      <div class="grid summary">
        {% for key, value in payload.system_summary.items() %}
        <div class="card">
          <div class="muted">{{ key }}</div>
          <div class="metric">{{ value }}</div>
        </div>
        {% endfor %}
      </div>
    </section>

    <section class="card" style="margin-bottom:24px">
      <h2>Temperature Timeline</h2>
      <canvas id="thermalChart" width="1100" height="280"></canvas>
      <div class="muted">CPU and GPU samples are populated when HWiNFO64 shared memory is available during stress tests.</div>
    </section>

    <section class="card" style="margin-bottom:24px">
      <h2>Recommendations</h2>
      {% if payload.recommendations %}
      <ul>
        {% for item in payload.recommendations %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% else %}
      <div class="muted">No WARN or FAIL items were recorded.</div>
      {% endif %}
    </section>

    <section>
      <h2>Per-Test Results</h2>
      <div class="grid results">
        {% for result in payload.results %}
        <article class="card">
          <div>
            <strong>{{ result.name }}</strong>
            <span class="badge {{ result.status }}">{{ result.status }}</span>
          </div>
          <div class="muted">{{ result.category }}</div>
          {% if result.metrics %}
          <table>
            {% for key, value in result.metrics.items() if key != "thermal_samples" %}
            <tr><th>{{ key }}</th><td>{{ value }}</td></tr>
            {% endfor %}
          </table>
          {% endif %}
          {% if result.notes %}
          <ul>
            {% for note in result.notes %}
            <li>{{ note }}</li>
            {% endfor %}
          </ul>
          {% endif %}
        </article>
        {% endfor %}
      </div>
    </section>
  </div>

  <script>
    const payload = {{ payload_json | safe }};
    const series = payload.thermal_series || [];
    const canvas = document.getElementById("thermalChart");
    const ctx = canvas.getContext("2d");
    const w = canvas.width;
    const h = canvas.height;

    function drawLine(points, key, color) {
      const values = points.map(p => p[key]).filter(v => typeof v === "number");
      if (!values.length) return;
      const max = Math.max(100, ...values);
      const min = 0;
      ctx.beginPath();
      ctx.strokeStyle = color;
      ctx.lineWidth = 3;
      points.forEach((p, i) => {
        if (typeof p[key] !== "number") return;
        const x = 42 + (i / Math.max(1, points.length - 1)) * (w - 70);
        const y = h - 34 - ((p[key] - min) / (max - min)) * (h - 60);
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      });
      ctx.stroke();
    }

    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = "#070a0f";
    ctx.fillRect(0, 0, w, h);
    ctx.strokeStyle = "#263244";
    ctx.lineWidth = 1;
    for (let i = 0; i <= 5; i++) {
      const y = 20 + i * ((h - 54) / 5);
      ctx.beginPath();
      ctx.moveTo(40, y);
      ctx.lineTo(w - 20, y);
      ctx.stroke();
    }
    ctx.fillStyle = "#9ca3af";
    ctx.font = "14px Consolas, monospace";
    ctx.fillText("CPU °C", 48, 22);
    ctx.fillStyle = "#00ff41";
    ctx.fillText("GPU °C", 120, 22);
    if (!series.length) {
      ctx.fillStyle = "#9ca3af";
      ctx.fillText("No thermal samples captured.", 46, 145);
    } else {
      drawLine(series, "cpu", "#d97706");
      drawLine(series, "gpu", "#00ff41");
    }
  </script>
</body>
</html>

